#!/usr/bin/env bash
# scripts/ralph — ralph loop for working through VPR slices via TDD.
#
# Each iteration: picks the next unimplemented slice from .vpr/meta.json,
# applies /tdd to make ONE acceptance criterion pass, runs the configured
# test command, appends progress, and commits. Stops when all slices are
# complete or when the agent requests human input.
#
# Usage: scripts/ralph <item> <max-iterations> [--prd <path>] [--test-cmd "<cmd>"] [--quiet]
#
#   <item>            — item name in .vpr/meta.json (e.g. safron-mvp2-ui-virtual)
#   <max-iterations>  — number of claude turns before auto-stop
#   --prd <path>      — optional file attached as parent context. If omitted, the
#                       item's parentWiDescription from meta.json is used inline.
#   --test-cmd "..."  — shell command to run between iterations for feedback.
#                       Defaults to "npm test".
#   --quiet           — minimal output mode for sandbox / non-tty use. Skips the
#                       jq event stream renderer; only prints iteration headers,
#                       PICKED lines, and promise signals. Full stream-json log
#                       still saved to .vpr/ralph.${ITEM}.iter${N}.jsonl per turn.

set -e

ITEM=""
MAX_ITER=""
PRD_FILE=""
TEST_CMD="npm test"
QUIET=0

# Positional args first, then flags.
while [[ $# -gt 0 ]]; do
  case "$1" in
    --prd)
      PRD_FILE="$2"
      shift 2
      ;;
    --test-cmd)
      TEST_CMD="$2"
      shift 2
      ;;
    --quiet)
      QUIET=1
      shift
      ;;
    -h|--help)
      grep '^# ' "$0" | sed 's/^# \?//'
      exit 0
      ;;
    *)
      if [ -z "$ITEM" ]; then ITEM="$1"
      elif [ -z "$MAX_ITER" ]; then MAX_ITER="$1"
      else
        echo "Unknown argument: $1" >&2
        exit 1
      fi
      shift
      ;;
  esac
done

if [ -z "$ITEM" ] || [ -z "$MAX_ITER" ]; then
  echo "Usage: $0 <item> <max-iterations> [--prd <path>] [--test-cmd \"<cmd>\"]"
  echo ""
  echo "Each iteration runs 'claude -p' once to advance one acceptance criterion"
  echo "of the highest-priority unblocked slice in <item>."
  echo ""
  echo "Exit signals (set by claude):"
  echo "  <promise>COMPLETE</promise>           → all slices done; ralph exits 0"
  echo "  <promise>SLICE-DONE</promise>         → this slice finished; ralph continues"
  echo "  <promise>HUMAN-INPUT-NEEDED</promise> → clarification needed; ralph exits 2"
  exit 1
fi

REPO_ROOT="$(git rev-parse --show-toplevel)"
PROGRESS_FILE="$REPO_ROOT/.vpr/progress.${ITEM}.txt"
META_FILE="$REPO_ROOT/.vpr/meta.json"
TDD_SKILL="$HOME/.claude/skills/tdd/SKILL.md"
CAVEMAN_SKILL="$HOME/.claude/plugins/marketplaces/caveman/skills/caveman/SKILL.md"

if [ ! -f "$META_FILE" ]; then
  echo "Error: $META_FILE not found. Run vpr init first." >&2
  exit 1
fi

if ! jq -e --arg item "$ITEM" '.items[$item]' "$META_FILE" >/dev/null 2>&1; then
  echo "Error: item '$ITEM' not found in $META_FILE" >&2
  exit 1
fi

# If no --prd supplied, materialise the item's parentWiDescription to a temp
# file so it can be @-attached just like a real PRD path. Empty when neither
# parentWiDescription nor wiDescription are populated.
TMP_PRD=""
if [ -z "$PRD_FILE" ]; then
  PARENT_DESC="$(jq -r --arg item "$ITEM" '.items[$item].parentWiDescription // .items[$item].wiDescription // ""' "$META_FILE")"
  if [ -n "$PARENT_DESC" ]; then
    TMP_PRD="$(mktemp -t vpr-ralph-prd.XXXXXX.md)"
    PARENT_TITLE="$(jq -r --arg item "$ITEM" '.items[$item].parentWiTitle // .items[$item].wiTitle // ""' "$META_FILE")"
    PARENT_WI="$(jq -r --arg item "$ITEM" '.items[$item].parentWi // .items[$item].wi // ""' "$META_FILE")"
    {
      [ -n "$PARENT_TITLE" ] && echo "# $PARENT_TITLE${PARENT_WI:+ (#$PARENT_WI)}" && echo ""
      echo "$PARENT_DESC"
    } > "$TMP_PRD"
    PRD_FILE="$TMP_PRD"
  fi
fi

cleanup() {
  [ -n "$TMP_PRD" ] && rm -f "$TMP_PRD"
  rm -f "$REPO_ROOT/.vpr/.ralph-meta-slim.json"
}
trap cleanup EXIT

mkdir -p "$(dirname "$PROGRESS_FILE")"
touch "$PROGRESS_FILE"

# Print a landscape snapshot: each slice with its blockers and a count of
# progress.txt entries (the agent's worklog).
print_slice_landscape() {
  echo "→ Slice landscape (entries in $PROGRESS_FILE | blocked-by):"
  # Read slice spec from `acceptance` field (machine-readable, holds
  # ## What to build / ## Acceptance criteria / ## Blocked by sections).
  # `story` is the human-curated PR narrative — separate concern, not the
  # spec ralph drives against.
  jq -r --arg item "$ITEM" '
    .items[$item].vprs | to_entries[] |
    .key as $bm |
    (.value.acceptance // "") as $spec |
    ($spec | capture("(?s)## Blocked by\\s*\n(?<b>.*?)(?=\n## |$)").b // "") as $blocked |
    "\($bm)\t\($blocked | gsub("\n"; " ") | gsub("^\\s+|\\s+$"; ""))"
  ' "$META_FILE" | while IFS=$'\t' read -r bookmark blocked; do
    short="${bookmark##*/}"
    count=$(grep -cF " $bookmark:" "$PROGRESS_FILE" 2>/dev/null || true)
    if [ "$count" -gt 0 ]; then marker="●"; else marker="○"; fi
    printf "    %s [%2d] %-32s  %s\n" "$marker" "$count" "$short" "${blocked:0:80}"
  done
}

for ((i=1; i<=MAX_ITER; i++)); do
  if [ "$QUIET" = "1" ]; then
    echo "[iter $i/$MAX_ITER] $ITEM"
  else
    echo ""
    echo "════════════════════════════════════════"
    echo "  Ralph iteration $i / $MAX_ITER  ($ITEM)"
    echo "════════════════════════════════════════"

    print_slice_landscape
    echo ""
    echo "→ Running '$TEST_CMD' to snapshot feedback state..."
  fi

  # Snapshot current feedback state so the agent sees what's failing right now.
  # Show the operator the full output for debugging, but only feed the agent the
  # last 30 lines — failing-test stack traces dominate context otherwise and the
  # tail almost always carries the actionable failure.
  TEST_RESULT_FULL=$(cd "$REPO_ROOT" && eval "$TEST_CMD" 2>&1 || true)
  [ "$QUIET" != "1" ] && echo "$TEST_RESULT_FULL" | tail -20
  TEST_RESULT=$(echo "$TEST_RESULT_FULL" | tail -30)
  if [ "$QUIET" != "1" ]; then
    echo ""
    echo "→ Dispatching claude for iteration $i..."
    echo "────────────────────────────────────────"
  fi

  # Slim the meta.json before attaching: drop eventLog (grows unbounded over
  # the life of the project, ~50% of file size for active repos) and any items
  # other than the one ralph is working on. Stable file path so Anthropic's
  # prompt cache keys hit across iterations within the 5-min TTL.
  META_SLIM="$REPO_ROOT/.vpr/.ralph-meta-slim.json"
  jq --arg item "$ITEM" '
    del(.eventLog)
    | .items |= with_entries(select(.key == $item))
  ' "$META_FILE" > "$META_SLIM"

  # Build @-attachments in stable order so identical prefixes cache across
  # iterations. PRD attached first (most stable), then slim meta, then skills,
  # then progress (changes least to most).
  ATTACH=""
  [ -n "$PRD_FILE" ] && ATTACH="@$PRD_FILE "
  ATTACH="${ATTACH}@$META_SLIM @$TDD_SKILL @$CAVEMAN_SKILL @$PROGRESS_FILE"

  # claude -p in default text mode emits nothing until the turn finishes.
  # Use --output-format stream-json --verbose to get one event per line as they
  # happen; tee raw JSON to a per-iteration log file (kept on disk for
  # postmortem) and pipe through jq to render output. Verbose mode renders
  # every tool call + text chunk; quiet mode emits only PICKED lines, promise
  # tags, and a one-line completion summary — suitable for sandbox / non-tty
  # contexts (sandcastle, CI).
  CLAUDE_OUT="$REPO_ROOT/.vpr/ralph.${ITEM}.iter${i}.jsonl"
  claude -p --verbose --output-format stream-json --permission-mode bypassPermissions "\
$ATTACH

You are working through item '$ITEM', one slice at a time, using strict TDD.

CONTEXT:
- The parent PRD (if attached above) holds problem, solution, user stories, implementation decisions, testing decisions.
- The slice plan lives in .vpr/meta.json under item '$ITEM'. Each VPR there is a slice; its 'acceptance' field holds the machine-readable TDD spec: ## What to build / ## Acceptance criteria / ## Blocked by. (The 'story' field is for human-curated PR narrative — usually written post-QA — and is NOT the spec.)
- Progress so far is in $PROGRESS_FILE (each line: timestamp, slice-bookmark, what was accomplished).
- The TDD skill governs HOW you implement: red-green-refactor, vertical tracer bullets, behavior-not-implementation tests.
- The caveman skill governs HOW you communicate: terse, drop articles/filler, fragments OK. Apply at intensity 'full' to ALL assistant text in this run (including the PICKED line, progress entry, and commit message subject — keep the conventional-commit prefix intact). Skip caveman only for the literal <promise>...</promise> tags and for any HUMAN-INPUT-NEEDED question (those need clarity).

THIS ITERATION:
0. As your VERY FIRST line of output (before any tool calls), print:
     PICKED: <slice-bookmark> — <one-sentence reason>
   so the operator can see what you chose.
1. Read .vpr/meta.json. Find the next slice to work on:
   - Skip slices whose 'acceptance' field is empty or has no '## Acceptance criteria' section — those are placeholders for future work, not yet specced.
   - Walk the remaining slices in 'Blocked by' order: a slice is workable only if all its blockers' acceptance criteria are met.
   - Among workable slices, pick the highest priority (earliest in dependency order).
   - If a slice is partially complete (some acceptance criteria done, some not), continue it before starting a new one.
2. Identify ONE acceptance criterion from that slice's 'acceptance' field that is not yet met.
3. Apply /tdd: write ONE failing test for that criterion (RED), then minimal implementation to pass (GREEN), then refactor if natural.
4. Run '$TEST_CMD'. ALL tests must be green before you finish this iteration. If a test you didn't touch is failing, fix it before moving on (treat it as a regression).
5. Append one line to $PROGRESS_FILE:
     '\$(date -Iminutes) <slice-bookmark>: <one-line summary of what you accomplished>'
6. Make a single git commit using conventional-commit format (e.g. 'feat(scope): summary'). One commit per iteration.
7. Tag the commit with the slice's jj bookmark so vpr status groups it under the slice:
     jj bookmark set <slice-bookmark> -r @- -B
   (the new commit is at @- after git commit in this colocated repo; -B permits sideways/backward moves on resumed slices.)

CONSTRAINTS:
- ONLY one acceptance criterion per iteration. Do NOT roll multiple together; the loop will continue.
- ONLY one slice per iteration. If you finish the slice, stop — the next iteration picks the next.
- If you need clarification on the slice's spec, the interface, or design intent, output <promise>HUMAN-INPUT-NEEDED</promise> followed by your question, then stop. Do NOT invent answers.
- If this slice's acceptance criteria are NOW all met, output <promise>SLICE-DONE</promise> at the end of your response.
- If EVERY slice in '$ITEM' has all acceptance criteria met, output <promise>COMPLETE</promise>.
- Never modify the parent PRD. If you discover the spec is wrong, output <promise>HUMAN-INPUT-NEEDED</promise> with the discrepancy.

CURRENT TEST STATE (output of '$TEST_CMD' just before this iteration):
$TEST_RESULT
" | tee "$CLAUDE_OUT" | jq --unbuffered -r '
      def short(s): if (s | length) > 100 then "…" + s[-99:] else s end;
      def dim(s): "[2m" + s + "[22m";
      def green(s): "[32m" + s + "[0m";
      if .type == "assistant" then
        .message.content[]? |
          if .type == "text" then
            .text
          elif .type == "tool_use" then
            "  [2m• \(.name)[22m " + short(
              if .name == "Read" or .name == "Edit" or .name == "Write" or .name == "NotebookEdit" then
                (.input.file_path // "?")
              elif .name == "Bash" then
                ((.input.command // "") | split("\n")[0])
              elif .name == "Grep" then
                "/\(.input.pattern // "?")/" + (if .input.path then " in \(.input.path)" else "" end)
              elif .name == "Glob" then
                (.input.pattern // "?") + (if .input.path then " in \(.input.path)" else "" end)
              elif .name == "TodoWrite" then
                "\(.input.todos | length) todos"
              elif .name == "Task" then
                (.input.description // .input.subagent_type // "?")
              else
                (.input | tostring)
              end
            )
          else empty end
      elif .type == "result" then
        "[32m✓ claude done (\((.duration_ms // 0) / 1000 | floor)s, \(.num_turns // 0) turns)[0m"
      else empty end
    ' | { if [ "$QUIET" = "1" ]; then
            # Strip ANSI, then keep only PICKED lines, <promise> tags, and the ✓ summary.
            sed 's/\x1b\[[0-9;]*m//g' | grep -E '^(PICKED:|.*<promise>|✓)' || true
          else
            cat
          fi; }

  result=$(<"$CLAUDE_OUT")

  if [ "$QUIET" != "1" ]; then
    echo ""
    echo "────────────────────────────────────────"
  fi

  # Safety net: ensure the slice bookmark lands on the new commit (@-) even if
  # the agent skipped step 7. Parses the PICKED: line the agent emits first.
  if [[ "$result" != *"<promise>HUMAN-INPUT-NEEDED</promise>"* ]]; then
    PICKED=$(printf '%s\n' "$result" \
      | jq -r 'select(.type=="assistant") | .message.content[]? | select(.type=="text") | .text' 2>/dev/null \
      | awk '/^PICKED:/{print $2; exit}')
    if [ -n "$PICKED" ]; then
      if (cd "$REPO_ROOT" && jj bookmark set "$PICKED" -r @- -B >/dev/null 2>&1); then
        [ "$QUIET" != "1" ] && echo "→ Bookmarked $PICKED on @-"
      else
        echo "warn: jj bookmark set failed for $PICKED (commit may be unchanged or @- empty)" >&2
      fi
    else
      echo "warn: no PICKED: line in agent output — bookmark not set" >&2
    fi
  fi

  if [[ "$result" == *"<promise>COMPLETE</promise>"* ]]; then
    if [ "$QUIET" = "1" ]; then
      echo "COMPLETE"
    else
      echo ""
      echo "════════════════════════════════════════"
      echo "  All slices complete — exiting."
      echo "════════════════════════════════════════"
    fi
    exit 0
  fi

  if [[ "$result" == *"<promise>HUMAN-INPUT-NEEDED</promise>"* ]]; then
    if [ "$QUIET" = "1" ]; then
      echo "HUMAN-INPUT-NEEDED"
    else
      echo ""
      echo "════════════════════════════════════════"
      echo "  Human input requested — exiting for review."
      echo "════════════════════════════════════════"
    fi
    exit 2
  fi
done

echo ""
echo "Ralph loop completed $MAX_ITER iterations without reaching COMPLETE."
